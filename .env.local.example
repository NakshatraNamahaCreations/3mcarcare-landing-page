# SMTP credentials for the /api/enquire route.
# Copy this file to .env.local and fill in real values.
#
# Configured for Hostinger Webmail (smtp.hostinger.com).
# To use a different provider, override SMTP_HOST / SMTP_PORT.
#
# Setup steps:
#   1. Log in to hPanel -> Emails -> Email Accounts.
#   2. Find info@3mcarcarestudios.in (or create it).
#   3. Click "Manage" -> "Configuration Settings" (or "Connect Apps & Devices").
#      Confirm the SMTP host (smtp.hostinger.com) and port (465 SSL).
#   4. Use the same password you set when creating the mailbox.
#      If you've forgotten it, click "Change Password" on that mailbox.
#   5. Paste the password as SMTP_PASS below.
#   6. Restart `npm run dev` after editing this file
#      (env vars only load at server boot).

# Hostinger SMTP server. Override only if Hostinger changes their host.
SMTP_HOST=smtp.hostinger.com

# 465 = SSL (default, recommended). 587 = STARTTLS.
SMTP_PORT=465

# The mailbox you authenticate with. Also appears as the email sender.
SMTP_USER=info@3mcarcarestudios.in

# The mailbox password (from hPanel -> Emails).
SMTP_PASS=your-mailbox-password-here

# Where enquiry emails are delivered. Defaults to SMTP_USER if unset.
# Use a comma-separated list to notify multiple people.
MAIL_TO=info@3mcarcarestudios.in

# Optional: override the "From" header. Defaults to:
#   "3M Car Care Website <SMTP_USER>"
# MAIL_FROM=3M Car Care Website <info@3mcarcarestudios.in>

# Controls whether the customer auto-reply is sent.
#   true   -> always send
#   false  -> never send (use for dev to stop test submissions from bouncing)
#   unset  -> auto: send when NODE_ENV=production, skip otherwise
# Leave commented out locally so dev tests don't trigger bounces back to the studio inbox.
# ENQUIRE_AUTO_REPLY=false
